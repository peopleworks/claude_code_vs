<?xml version="1.0" encoding="utf-8"?>
<!--
  In-proc VSIX for VS 2026 (Dev18). net48, VSSDK + Community Toolkit.

  Package strategy (verified against this machine, 2026-06):
    * Build against the 17.x VS SDK reference assemblies (the only ones on NuGet today); a
      17.x-SDK extension runs in VS 2026 via assembly unification.
    * Microsoft.VSSDK.BuildTools 18.6 (Dev18) packages the .vsix and understands the [18.0,19.0)
      installation target so it installs into VS 2026 only.
  The pure-BCL protocol core is a ProjectReference; its DLL rides into the .vsix automatically.
-->
<Project ToolsVersion="Current" DefaultTargets="Build" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <Import Project="$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props" Condition="Exists('$(MSBuildExtensionsPath)\$(MSBuildToolsVersion)\Microsoft.Common.props')" />

  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <Platform Condition=" '$(Platform)' == '' ">AnyCPU</Platform>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{209981D1-0325-4FAD-B5F4-3D8662DBFEF9}</ProjectGuid>
    <ProjectTypeGuids>{82b43b9b-a64c-4715-b499-d71e9ca2bd60};{FAE04EC0-301F-11D3-BF4B-00C04F79EFBC}</ProjectTypeGuids>
    <OutputType>Library</OutputType>
    <AppDesignerFolder>Properties</AppDesignerFolder>
    <RootNamespace>ClaudeCodeVs</RootNamespace>
    <AssemblyName>ClaudeCodeVS</AssemblyName>
    <TargetFrameworkVersion>v4.8</TargetFrameworkVersion>
    <LangVersion>latest</LangVersion>
    <Nullable>enable</Nullable>
    <GeneratePkgDefFile>true</GeneratePkgDefFile>
    <IncludeAssemblyInVSIXContainer>true</IncludeAssemblyInVSIXContainer>
    <IncludeDebugSymbolsInVSIXContainer>false</IncludeDebugSymbolsInVSIXContainer>
    <IncludeDebugSymbolsInLocalVSIXDeployment>false</IncludeDebugSymbolsInLocalVSIXDeployment>
    <CopyBuildOutputToOutputDirectory>true</CopyBuildOutputToOutputDirectory>
    <CopyOutputSymbolsToOutputDirectory>false</CopyOutputSymbolsToOutputDirectory>
    <!-- F5 launches the VS 2026 experimental instance with the VSIX loaded. -->
    <StartAction>Program</StartAction>
    <StartProgram Condition="'$(DevEnvDir)' != ''">$(DevEnvDir)devenv.exe</StartProgram>
    <StartArguments>/rootsuffix Exp</StartArguments>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Debug|AnyCPU' ">
    <DebugSymbols>true</DebugSymbols>
    <DebugType>full</DebugType>
    <Optimize>false</Optimize>
    <OutputPath>bin\Debug\</OutputPath>
    <DefineConstants>DEBUG;TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <PropertyGroup Condition=" '$(Configuration)|$(Platform)' == 'Release|AnyCPU' ">
    <DebugType>pdbonly</DebugType>
    <Optimize>true</Optimize>
    <OutputPath>bin\Release\</OutputPath>
    <DefineConstants>TRACE</DefineConstants>
    <ErrorReport>prompt</ErrorReport>
    <WarningLevel>4</WarningLevel>
  </PropertyGroup>

  <ItemGroup>
    <Compile Include="**\*.cs" Exclude="bin\**;obj\**" />
  </ItemGroup>

  <!-- WPF for the dockable tool window (net48 framework assemblies). -->
  <ItemGroup>
    <Reference Include="PresentationCore" />
    <Reference Include="PresentationFramework" />
    <Reference Include="WindowsBase" />
    <Reference Include="System.Xaml" />
  </ItemGroup>

  <ItemGroup>
    <None Include="source.extension.vsixmanifest">
      <SubType>Designer</SubType>
    </None>
  </ItemGroup>

  <!-- VSIX marketplace assets: icon (90x90) and preview (200x200). -->
  <ItemGroup>
    <Content Include="Resources\icon.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
    <Content Include="Resources\preview.png">
      <IncludeInVSIX>true</IncludeInVSIX>
    </Content>
  </ItemGroup>

  <!-- Hook scripts, embedded so the extension can write them into a workspace's .claude/ folder on
       launch: the single-gate PreToolUse hook and the Stop usage-stats hook. -->
  <ItemGroup>
    <EmbeddedResource Include="Hooks\vs-permission-hook.ps1" />
    <EmbeddedResource Include="Hooks\vs-usage-hook.ps1" />
    <EmbeddedResource Include="Hooks\vs-debug-context-hook.ps1" />
    <!-- Phase 2 debug PULL channel: the stdio MCP shim, registered in .mcp.json (see McpInstaller). -->
    <EmbeddedResource Include="Hooks\vs-mcp-shim.ps1" />
  </ItemGroup>

  <ItemGroup>
    <!-- Compiled into the Menus.ctmenu resource referenced by [ProvideMenuResource]. -->
    <VSCTCompile Include="VSCommandTable.vsct">
      <ResourceName>Menus.ctmenu</ResourceName>
    </VSCTCompile>
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.VisualStudio.SDK" Version="17.14.40265" ExcludeAssets="runtime" />
    <PackageReference Include="Microsoft.VSSDK.BuildTools" Version="18.6.38345">
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
      <PrivateAssets>all</PrivateAssets>
    </PackageReference>
    <PackageReference Include="Community.VisualStudio.Toolkit.17" Version="17.0.551" />
    <!-- Roslyn semantic model (vs-semantic server). Compile-time ONLY: ExcludeAssets="runtime" so we
         bind to devenv's own Microsoft.CodeAnalysis.*/LanguageServices at runtime and never ship a
         second copy (a version skew here = the MissingMethodException class that exiled ClrMD). VS
         hosts Roslyn in-proc and VisualStudioWorkspace is the supported extension entry point, so
         unlike ClrMD this works in-proc. Bringing LanguageServices transitively pulls the
         Microsoft.CodeAnalysis.Workspaces compile refs (SymbolFinder, Solution, DocumentationCommentId). -->
    <PackageReference Include="Microsoft.VisualStudio.LanguageServices" Version="4.14.0" ExcludeAssets="runtime" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ClaudeCodeVS.Protocol\ClaudeCodeVS.Protocol.csproj" />
    <!-- The Concord data-breakpoint component. OUTPUT-ONLY (ReferenceOutputAssembly=false): VS's
         debug engine loads it via its .vsdconfig (declared as a DebuggerEngineExtension asset in the
         manifest); the extension never references its code. The output groups carry the component
         DLL + the compiled .vsdconfig into the .vsix root. -->
    <ProjectReference Include="..\ClaudeCodeVS.DataBpComponent\ClaudeCodeVS.DataBpComponent.csproj">
      <Name>ClaudeCodeVS.DataBpComponent</Name>
      <IncludeOutputGroupsInVSIX>BuiltProjectOutputGroup%3bBuiltProjectOutputGroupDependencies%3bGetCopyToOutputDirectoryItems%3bSatelliteDllsProjectOutputGroup%3b</IncludeOutputGroupsInVSIX>
      <ReferenceOutputAssembly>false</ReferenceOutputAssembly>
    </ProjectReference>
  </ItemGroup>

  <Import Project="$(MSBuildToolsPath)\Microsoft.CSharp.targets" />
  <Import Project="$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets" Condition="'$(VSToolsPath)' != '' And Exists('$(VSToolsPath)\VSSDK\Microsoft.VsSDK.targets')" />

  <!--
    Build the out-of-process ClrMD worker and ship its WHOLE output folder inside the .vsix under
    ClrMdWorker\. The extension launches ClrMdWorker.exe as a child process (so ClrMD never loads in
    devenv's AppDomain - that's the conflict we hit). It is deliberately NOT a ProjectReference, so its
    assemblies never enter the extension's load context.
  -->
  <Target Name="BuildAndBundleClrMdWorker" BeforeTargets="GetVsixSourceItems">
    <MSBuild Projects="..\ClaudeCodeVS.ClrMdWorker\ClrMdWorker.csproj" Targets="Restore" Properties="Configuration=$(Configuration)" />
    <MSBuild Projects="..\ClaudeCodeVS.ClrMdWorker\ClrMdWorker.csproj" Targets="Build" Properties="Configuration=$(Configuration)" />
    <ItemGroup>
      <_ClrMdWorkerFile Include="..\ClaudeCodeVS.ClrMdWorker\bin\$(Configuration)\net48\**\*.*" />
      <VSIXSourceItem Include="@(_ClrMdWorkerFile)">
        <VSIXSubPath>ClrMdWorker\%(RecursiveDir)</VSIXSubPath>
      </VSIXSourceItem>
    </ItemGroup>
  </Target>
</Project>
