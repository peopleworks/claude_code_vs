<?xml version="1.0" encoding="utf-8"?>
<!--
  Concord component registration. vsdconfigtool.exe (from the VSDConfigTool NuGet package)
  compiles this to a binary ConcordSpike.vsdconfig at build time; that .vsdconfig is shipped
  in the VSIX as a DebuggerEngineExtension asset and read by the engine's component loader.

  ComponentLevel 9995000 = an IDE-level component (> 100,000), which is the correct tier for a
  call-stack filter (it runs in devenv). NOTE for Rung 1: the managed data-breakpoint API needs
  a MONITOR-level component (< 100,000) running in msvsmon - a different ComponentLevel and a
  different deployment surface. This Rung-0 probe deliberately uses the simplest (IDE) tier.

  ComponentId is freshly generated (the sample requires regenerating it on copy).
-->
<Configuration xmlns="http://schemas.microsoft.com/vstudio/vsdconfig/2008">

  <ManagedComponent
    ComponentId="EB4A9D70-0863-4184-9B3F-112921D175A3"
    ComponentLevel="9995000"
    AssemblyName="ConcordSpike">

    <Class Name="ConcordSpike.SpikeService">
      <Implements>
        <InterfaceGroup>
          <NoFilter/>
          <!-- Request-thread arm trigger (+ load canary) -->
          <Interface Name="IDkmCallStackFilter"/>
          <!-- Change events -->
          <Interface Name="IDkmDataBreakpointHitNotification"/>
        </InterfaceGroup>
      </Implements>
    </Class>

  </ManagedComponent>
</Configuration>
